generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum LogAction {
  CREATE
  UPDATE
  DELETE
}

model Wish {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(50)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("wishes")
}

model WishLog {
  id        String    @id @default(uuid()) @db.Uuid
  action    LogAction
  wishId    String    @db.Uuid
  wishTitle String    @db.VarChar(50)
  oldValues Json?
  newValues Json?
  createdAt DateTime  @default(now())

  @@map("wish_logs")
}

model RequestLog {
  id        String   @id @default(uuid()) @db.Uuid
  method    String   @db.VarChar(10)
  url       String   @db.Text
  body      String?  @db.Text
  createdAt DateTime @default(now())

  @@map("request_logs")
}
